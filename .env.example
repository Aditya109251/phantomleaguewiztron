# Neon DB
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Phantom League" <your-email@gmail.com>

# Cashfree API Keys
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_MODE=sandbox # Set to 'production' for real payments

# App URL (for payment redirect)
APP_URL=
